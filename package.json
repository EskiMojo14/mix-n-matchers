{
  "name": "mix-n-matchers",
  "version": "2.2.0",
  "description": "Miscellaneous custom Jest matchers",
  "keywords": [
    "assertions",
    "extend",
    "extended",
    "jest",
    "matchers",
    "test",
    "testing",
    "vitest"
  ],
  "homepage": "https://github.com/EskiMojo14/mix-n-matchers#readme",
  "bugs": {
    "url": "https://github.com/EskiMojo14/mix-n-matchers/issues"
  },
  "license": "MIT",
  "author": "eskimojo",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/EskiMojo14/mix-n-matchers.git"
  },
  "files": [
    "dist",
    "types",
    "all",
    "jest-globals",
    "vitest",
    "utilities"
  ],
  "type": "module",
  "main": "./dist/index.cjs",
  "module": "./dist/index.mjs",
  "types": "./dist/index.d.mts",
  "exports": {
    "./package.json": "./package.json",
    ".": {
      "import": {
        "types": "./dist/index.d.mts",
        "default": "./dist/index.mjs"
      },
      "require": {
        "types": "./dist/index.d.cts",
        "default": "./dist/index.cjs"
      }
    },
    "./all": {
      "import": {
        "types": "./types/all.d.mts",
        "default": "./dist/all.mjs"
      },
      "require": {
        "types": "./types/all.d.cts",
        "default": "./dist/all.cjs"
      }
    },
    "./jest-globals": {
      "import": {
        "types": "./types/jest-globals.d.mts",
        "default": "./dist/jest-globals.mjs"
      },
      "require": {
        "types": "./types/jest-globals.d.cts",
        "default": "./dist/jest-globals.cjs"
      }
    },
    "./vitest": {
      "import": {
        "types": "./types/vitest.d.mts",
        "default": "./dist/vitest.mjs"
      },
      "require": {
        "types": "./types/vitest.d.cts",
        "default": "./dist/vitest.cjs"
      }
    },
    "./utilities": {
      "import": {
        "types": "./dist/utilities/index.d.mts",
        "default": "./dist/utilities/index.mjs"
      },
      "require": {
        "types": "./dist/utilities/index.d.cts",
        "default": "./dist/utilities/index.cjs"
      }
    }
  },
  "scripts": {
    "clean": "rimraf dist",
    "prepare": "husky",
    "prebuild": "pnpm run typecheck",
    "build": "pnpm clean && tsdown",
    "test": "pnpm node --experimental-vm-modules node_modules/jest/bin/jest.js --setupFilesAfterEnv ./src/jest-globals.ts ./jest-setup.ts",
    "test:dist": "pnpm node --experimental-vm-modules node_modules/jest/bin/jest.js --setupFilesAfterEnv mix-n-matchers/jest-globals ./jest-setup.ts",
    "vitest": "vitest",
    "vitest:dist": "vitest --config vitest-dist.config.ts",
    "test:all": "pnpm run test && pnpm run vitest --run",
    "test:all:dist": "pnpm run test:dist && pnpm run vitest:dist --run",
    "lint": "oxlint",
    "format": "oxfmt",
    "pre-commit": "lint-staged",
    "attw": "attw",
    "publint": "publint",
    "typecheck": "tsgo",
    "prepack": "pnpm run publint --pack false",
    "website": "pnpm --filter website start"
  },
  "dependencies": {
    "@jest/expect-utils": "^30.4.1",
    "jest-matcher-utils": "^30.4.1"
  },
  "devDependencies": {
    "@arethetypeswrong/cli": "^0.18.3",
    "@jest/expect": "^30.4.1",
    "@jest/globals": "^30.4.1",
    "@types/node": "^25.9.3",
    "@typescript/native-preview": "catalog:",
    "@vitest/expect": "^4.1.9",
    "ansi-regex": "^6.2.2",
    "ansi-styles": "^6.2.3",
    "expect": "^30.4.1",
    "husky": "^9.1.7",
    "jest": "^30.4.2",
    "lint-staged": "^17.0.7",
    "oxfmt": "^0.55.0",
    "oxlint": "^1.70.0",
    "oxlint-tsgolint": "^0.23.0",
    "publint": "^0.3.21",
    "rimraf": "^6.1.3",
    "ts-jest": "^29.4.11",
    "ts-node": "^10.9.2",
    "tsdown": "^0.22.2",
    "typescript": "catalog:",
    "vitest": "^4.1.9"
  },
  "peerDependencies": {
    "jest": ">=28.0.0",
    "vitest": ">=1.0.0"
  },
  "peerDependenciesMeta": {
    "jest": {
      "optional": true
    },
    "vitest": {
      "optional": true
    }
  },
  "lint-staged": {
    "*": "oxfmt --no-error-on-unmatched-pattern"
  },
  "tsdown": {
    "deps": {
      "neverBundle": [
        "@jest/globals"
      ]
    },
    "dts": {
      "entry": [
        "src/index.ts",
        "src/utilities/index.ts"
      ]
    },
    "entry": [
      "src/index.ts",
      "src/all.ts",
      "src/jest-globals.ts",
      "src/vitest.ts",
      "src/utilities/index.ts"
    ],
    "format": [
      "esm",
      "cjs"
    ],
    "sourcemap": true
  },
  "engines": {
    "node": "^14.15.0 || ^16.10.0 || >=18.0.0"
  },
  "packageManager": "pnpm@11.7.0+sha512.19cc852c120c7125760f2443ee6be0ca5b40f9f50598de1a09a1f177503e010e57c23c77646e01e761de59bf874fb22a3398c33ab9691fc13eb946b6f0f4d620"
}
